ENVIRONMENT=development
DATABASE_URL=sqlite:///./llm_eval.db
DEFAULT_CONTRACT_PATH=contracts/default.yaml
API_KEY=change-me
REQUIRE_AUTH=false
LLM_PROVIDER=heuristic
LLM_MODEL=grok-2-1212
XAI_API_KEY=
XAI_BASE_URL=https://api.x.ai/v1
TRANSLATION_PROVIDER=heuristic
TRANSLATION_MODEL=grok-2-1212
EMBEDDING_PROVIDER=lexical
EMBEDDING_MODEL=text-embedding-3-small
LANGUAGE_MODE=auto
DEFAULT_OUTPUT_LANGUAGE=en
STRICT_LANGUAGE_MATCH=true
ALLOW_LANGUAGE_OVERRIDE=true
LANGUAGE_RETRY_LIMIT=2
KNOWLEDGE_BASE_PATH=backend/rag/knowledge_base
BACKEND_CORS_ORIGINS=http://localhost:5173
VITE_API_BASE=http://127.0.0.1:8000/api
